{% extends "base.html.twig" %}

{% block title %}Réserver — {{ event.title }}{% endblock %}

{% block body %}
    <a href="{{ path('app_event_detail', {id: event.id}) }}"
       class="inline-flex items-center gap-2 text-gray-500 hover:text-accent text-sm font-medium uppercase tracking-[0.08em] no-underline mb-6 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Retour à l'événement
    </a>

    <div class="max-w-xl mx-auto">
        <div class="mb-8">
            <span class="text-accent font-semibold text-xs uppercase tracking-[0.2em]">Réservation</span>
            <h1 class="font-display text-4xl font-extrabold text-gray-900 mt-2 tracking-tight leading-tight">
                {{ event.title }}
            </h1>
            <div class="flex flex-wrap gap-4 mt-3 text-gray-400 text-sm">
                <span class="flex items-center gap-1.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    {{ event.date|date('d/m/Y à H:i') }}
                </span>
                <span class="flex items-center gap-1.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    {{ event.location }}
                </span>
            </div>
        </div>

        <form method="post" action="{{ path('app_reservation_submit', {id: event.id}) }}"
              class="bg-warm-card border-2 border-gray-900 p-8">
            <div class="mb-5">
                <label for="name" class="block text-gray-900 text-xs font-bold uppercase tracking-[0.12em] mb-2">
                    Nom complet
                </label>
                <input type="text" id="name" name="name"
                       required
                       placeholder="Votre nom"
                       class="w-full border-2 border-gray-300 bg-white px-4 py-3 text-gray-900 text-sm font-medium focus:outline-none focus:border-gray-900 transition-colors">
            </div>

            <div class="mb-5">
                <label for="email" class="block text-gray-900 text-xs font-bold uppercase tracking-[0.12em] mb-2">
                    Adresse e-mail
                </label>
                <input type="email" id="email" name="email"
                       required
                       placeholder="votre@email.com"
                       class="w-full border-2 border-gray-300 bg-white px-4 py-3 text-gray-900 text-sm font-medium focus:outline-none focus:border-gray-900 transition-colors">
            </div>

            <div class="mb-8">
                <label for="phone" class="block text-gray-900 text-xs font-bold uppercase tracking-[0.12em] mb-2">
                    Téléphone
                </label>
                <input type="tel" id="phone" name="phone"
                       required
                       placeholder="+216 XX XXX XXX"
                       class="w-full border-2 border-gray-300 bg-white px-4 py-3 text-gray-900 text-sm font-medium focus:outline-none focus:border-gray-900 transition-colors">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('reservation_' ~ event.id) }}">

            <button type="submit"
                    class="w-full bg-gray-900 text-white py-3.5 font-bold text-sm uppercase tracking-[0.1em] hover:bg-accent hover:-translate-y-0.5 hover:shadow-[4px_6px_0_rgba(0,0,0,0.2)] active:translate-y-0 active:shadow-none transition-all">
                Confirmer la réservation
            </button>
        </form>
    </div>
{% endblock %}

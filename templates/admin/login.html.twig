{% extends "base.html.twig" %}

{% block title %}Administration — Connexion{% endblock %}

{% block body %}
    <div class="max-w-md mx-auto mt-8">
        <div class="mb-8">
            <span class="text-accent font-semibold text-xs uppercase tracking-[0.2em]">Accès restreint</span>
            <h1 class="font-display text-4xl font-extrabold text-gray-900 mt-2 tracking-tight">Administration</h1>
            <p class="text-gray-400 mt-2 text-sm">Espace réservé aux administrateurs</p>
        </div>

        {% if error %}
            <div class="mb-6 p-4 bg-red-50 border-l-4 border-red-600 text-red-800 font-medium text-sm">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_admin_login') }}" class="bg-warm-card border-2 border-gray-900 p-8">
            <div class="flex items-center gap-3 mb-6 pb-6 border-b border-gray-200">
                <div class="w-8 h-8 bg-gray-900 flex items-center justify-center">
                    <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
                    </svg>
                </div>
                <span class="text-gray-500 text-xs font-semibold uppercase tracking-[0.12em]">Panneau d'administration</span>
            </div>

            <div class="mb-5">
                <label for="username" class="block text-gray-900 text-xs font-bold uppercase tracking-[0.12em] mb-2">
                    Email
                </label>
                <input type="email" id="username" name="_username"
                       value="{{ last_username }}"
                       autocomplete="email"
                       required
                       class="w-full border-2 border-gray-300 bg-white px-4 py-3 text-gray-900 text-sm font-medium focus:outline-none focus:border-gray-900 transition-colors">
            </div>

            <div class="mb-6">
                <label for="password" class="block text-gray-900 text-xs font-bold uppercase tracking-[0.12em] mb-2">
                    Mot de passe
                </label>
                <input type="password" id="password" name="_password"
                       autocomplete="current-password"
                       required
                       class="w-full border-2 border-gray-300 bg-white px-4 py-3 text-gray-900 text-sm font-medium focus:outline-none focus:border-gray-900 transition-colors">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_authenticate') }}">

            <button type="submit"
                    class="w-full bg-gray-900 text-white py-3.5 font-bold text-sm uppercase tracking-[0.1em] hover:bg-accent hover:-translate-y-0.5 hover:shadow-[4px_6px_0_rgba(0,0,0,0.2)] active:translate-y-0 active:shadow-none transition-all">
                Accéder au panneau
            </button>
        </form>
    </div>
{% endblock %}

{% extends "base.html.twig" %}

{% block title %}Administration — Connexion{% endblock %}

{% block body %}
    <div class="max-w-md mx-auto">
        <div class="text-center mb-8">
            <span class="text-accent font-semibold text-xs uppercase tracking-[0.25em]">Accès restreint</span>
            <h1 class="font-display text-3xl sm:text-4xl font-bold text-primary mt-2 tracking-tight">Administration</h1>
            <p class="text-gray-500 mt-2 text-sm">Espace réservé aux administrateurs</p>
        </div>

        {% if error %}
            <div class="mb-6 p-4 bg-red-50 border border-red-100 text-red-700 font-medium text-sm rounded-lg">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_admin_login') }}" class="bg-card border border-gray-100 shadow-lg p-8 rounded-xl">
            <div class="flex items-center gap-3 mb-6 pb-6 border-b border-gray-100">
                <div class="w-10 h-10 bg-primary flex items-center justify-center rounded-lg">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
                    </svg>
                </div>
                <span class="text-gray-500 text-sm font-medium">Panneau d'administration</span>
            </div>

            <div class="mb-5">
                <label for="username" class="block text-primary text-sm font-medium mb-2">
                    Email
                </label>
                <input type="email" id="username" name="_username"
                       value="{{ last_username }}"
                       autocomplete="email"
                       required
                       class="w-full border border-gray-200 bg-surface px-4 py-3 text-primary text-sm rounded-lg focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors">
            </div>

            <div class="mb-6">
                <label for="password" class="block text-primary text-sm font-medium mb-2">
                    Mot de passe
                </label>
                <input type="password" id="password" name="_password"
                       autocomplete="current-password"
                       required
                       class="w-full border border-gray-200 bg-surface px-4 py-3 text-primary text-sm rounded-lg focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_authenticate') }}">

            <button type="submit"
                    class="w-full bg-primary text-white py-3.5 font-medium text-sm rounded-lg hover:bg-accent hover:-translate-y-0.5 hover:shadow-lg transition-all">
                Accéder au panneau
            </button>
        </form>
    </div>
{% endblock %}

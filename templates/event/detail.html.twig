{% extends "base.html.twig" %}

{% block title %}{{ event.title }}{% endblock %}

{% block body %}
    <a href="{{ path('app_event_list') }}"
       class="inline-flex items-center gap-2 text-gray-500 hover:text-accent text-sm font-medium uppercase tracking-[0.08em] no-underline mb-6 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Retour aux événements
    </a>

    <div class="relative mb-8">
        <img src="{{ event.image ?? '/images/event-placeholder.jpg' }}" alt="{{ event.title }}"
             class="w-full h-[400px] md:h-[450px] object-cover border-2 border-gray-900">
        <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black/60 to-transparent"></div>
        <span class="absolute top-4 left-4 bg-accent text-white text-xs font-bold uppercase tracking-[0.12em] px-4 py-2">
            {{ event.date|date('d M Y') }}
        </span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2">
            <h1 class="font-display text-4xl md:text-5xl font-extrabold text-gray-900 mb-6 tracking-tight leading-[1.1]">
                {{ event.title }}
            </h1>

            <div class="flex flex-wrap gap-6 pb-6 mb-6 border-b border-gray-300">
                <div class="flex items-center gap-3">
                    <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    <div>
                        <span class="block text-gray-400 text-[0.65rem] font-semibold uppercase tracking-[0.12em]">Date</span>
                        <span class="font-medium text-gray-900">{{ event.date|date('d/m/Y à H:i') }}</span>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    <div>
                        <span class="block text-gray-400 text-[0.65rem] font-semibold uppercase tracking-[0.12em]">Lieu</span>
                        <span class="font-medium text-gray-900">{{ event.location }}</span>
                    </div>
                </div>
            </div>

            <h2 class="font-display text-xl font-bold text-gray-900 mb-3">À propos</h2>
            <p class="text-gray-500 leading-relaxed text-base">{{ event.description }}</p>
        </div>

        <div class="lg:col-span-1">
            <div class="bg-warm-card border-2 border-gray-900 p-6 sticky top-24">
                <h3 class="font-display text-lg font-bold text-gray-900 mb-5">Réservation</h3>

                {% set fillPercent = event.seats > 0 ? ((event.seats - remainingSeats) / event.seats * 100) : 100 %}

                <span class="block text-gray-400 text-[0.65rem] font-semibold uppercase tracking-[0.12em] mb-1">Places disponibles</span>
                <div class="mb-3">
                    <span class="font-display text-4xl font-extrabold text-gray-900 leading-none">{{ remainingSeats }}</span>
                    <span class="text-gray-400 text-base">/ {{ event.seats }}</span>
                </div>

                <div class="w-full h-1.5 bg-gray-200 mb-1">
                    <div class="h-full {{ fillPercent > 80 ? 'bg-red-500' : 'bg-accent' }} transition-all duration-1000"
                         style="width: {{ fillPercent }}%"></div>
                </div>

                {% if remainingSeats > 0 and remainingSeats <= 10 %}
                    <span class="text-red-500 text-xs font-medium">Plus que {{ remainingSeats }} place{{ remainingSeats > 1 ? 's' : '' }} !</span>
                {% endif %}

                <div class="mt-6">
                    {% if remainingSeats > 0 %}
                        <a href="/events/{{ event.id }}/reserve"
                           class="block w-full bg-gray-900 text-white text-center py-3.5 font-bold text-sm uppercase tracking-[0.1em] no-underline hover:bg-accent hover:-translate-y-0.5 hover:shadow-[4px_6px_0_rgba(0,0,0,0.2)] active:translate-y-0 active:shadow-none transition-all">
                            Réserver une place
                        </a>
                    {% else %}
                        <button disabled
                                class="block w-full bg-gray-200 text-gray-400 text-center py-3.5 font-bold text-sm uppercase tracking-[0.1em] cursor-not-allowed">
                            Complet
                        </button>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

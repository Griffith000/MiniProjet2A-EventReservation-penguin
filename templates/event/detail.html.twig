{% extends "base.html.twig" %}

{% block title %}{{ event.title }}{% endblock %}

{% block body %}
    <a href="{{ path('app_event_list') }}"
       class="inline-flex items-center gap-2 text-gray-500 hover:text-accent text-sm font-medium no-underline mb-6 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Retour aux événements
    </a>

    <div class="relative mb-8 rounded-2xl overflow-hidden">
        <img src="{{ event.image ?? '/images/event-placeholder.jpg' }}" alt="{{ event.title }}"
             class="w-full h-[300px] md:h-[450px] object-cover">
        <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black/70 to-transparent"></div>
        <span class="absolute top-4 left-4 bg-white/95 backdrop-blur text-primary text-xs font-semibold uppercase tracking-wider px-4 py-2 rounded-full">
            {{ event.date|date('d M Y') }}
        </span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2">
            <h1 class="font-display text-3xl md:text-4xl font-bold text-primary mb-6 tracking-tight leading-[1.1]">
                {{ event.title }}
            </h1>

            <div class="flex flex-wrap gap-6 pb-6 mb-6 border-b border-gray-200">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-accent-light rounded-full flex items-center justify-center">
                        <svg class="w-5 h-5 text-accent-dark" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    </div>
                    <div>
                        <span class="block text-gray-400 text-xs font-medium">Date</span>
                        <span class="font-medium text-primary">{{ event.date|date('d/m/Y à H:i') }}</span>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-accent-light rounded-full flex items-center justify-center">
                        <svg class="w-5 h-5 text-accent-dark" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    </div>
                    <div>
                        <span class="block text-gray-400 text-xs font-medium">Lieu</span>
                        <span class="font-medium text-primary">{{ event.location }}</span>
                    </div>
                </div>
            </div>

            <h2 class="font-display text-xl font-semibold text-primary mb-3">À propos</h2>
            <p class="text-gray-500 leading-relaxed text-base">{{ event.description }}</p>
        </div>

        <div class="lg:col-span-1">
            <div class="bg-card border border-gray-100 shadow-lg p-6 rounded-xl sticky top-24">
                <h3 class="font-display text-lg font-semibold text-primary mb-5">Réservation</h3>

                {% set fillPercent = event.seats > 0 ? ((event.seats - remainingSeats) / event.seats * 100) : 100 %}

                <span class="block text-gray-400 text-xs font-medium mb-1">Places disponibles</span>
                <div class="mb-3">
                    <span class="font-display text-4xl font-bold text-primary leading-none">{{ remainingSeats }}</span>
                    <span class="text-gray-400 text-base">/ {{ event.seats }}</span>
                </div>

                <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden mb-1">
                    <div class="h-full {{ fillPercent > 80 ? 'bg-red-500' : 'bg-accent' }} transition-all duration-1000 rounded-full"
                         style="width: {{ fillPercent }}%"></div>
                </div>

                {% if remainingSeats > 0 and remainingSeats <= 10 %}
                    <span class="text-red-500 text-xs font-medium">Plus que {{ remainingSeats }} place{{ remainingSeats > 1 ? 's' : '' }} !</span>
                {% endif %}

                <div class="mt-6">
                    {% if remainingSeats > 0 %}
                        <a href="{{ path('app_reservation_form', {id: event.id}) }}"
                           class="block w-full bg-primary text-white text-center py-3.5 font-medium text-sm rounded-lg hover:bg-accent hover:-translate-y-0.5 hover:shadow-lg transition-all">
                            Réserver une place
                        </a>
                    {% else %}
                        <button disabled
                                class="block w-full bg-gray-100 text-gray-400 text-center py-3.5 font-medium text-sm rounded-lg cursor-not-allowed">
                            Complet
                        </button>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

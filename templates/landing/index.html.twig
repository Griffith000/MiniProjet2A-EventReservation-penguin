{% extends 'base.html.twig' %}

{% block title %}EventHub - Réservez des expériences uniques{% endblock %}

{% block body %}
<div class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10">
        <div class="absolute inset-0 bg-gradient-to-br from-surface via-surface to-accent-light/30"></div>
        <div class="absolute top-20 right-0 w-96 h-96 bg-accent/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-80 h-80 bg-primary/5 rounded-full blur-3xl"></div>
    </div>

    <section class="min-h-[85vh] flex items-center">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
            <div class="grid lg:grid-cols-2 gap-12 items-center">
                <div class="space-y-8">
                    <div class="inline-flex items-center gap-2 px-4 py-2 bg-accent-light rounded-full">
                        <span class="w-2 h-2 bg-accent rounded-full animate-pulse"></span>
                        <span class="text-sm font-medium text-accent-dark">Plateforme de réservation premium</span>
                    </div>
                    <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl font-bold text-primary leading-tight">
                        Découvrez des <span class="text-accent">événements</span> inoubliables
                    </h1>
                    <p class="text-xl text-gray-600 max-w-lg leading-relaxed">
                        Réservez vos places pour les concerts, conférences et expériences uniques. Une plateforme élégante pour des moments extraordinaires.
                    </p>
                    <div class="flex flex-wrap gap-4">
                        <a href="{{ path('app_event_list') }}" class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-white font-medium rounded-xl hover:bg-primary-light transition-all hover:scale-105 shadow-lg shadow-primary/20">
                            Explorer les événements
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                        </a>
                        <a href="{{ path('app_register') }}" class="inline-flex items-center gap-2 px-8 py-4 bg-white text-primary border-2 border-gray-200 font-medium rounded-xl hover:border-accent hover:text-accent transition-all">
                            Créer un compte
                        </a>
                    </div>
                    <div class="flex items-center gap-8 pt-4">
                        <div class="text-center">
                            <div class="font-display text-3xl font-bold text-primary">500+</div>
                            <div class="text-sm text-gray-500">Événements</div>
                        </div>
                        <div class="w-px h-12 bg-gray-200"></div>
                        <div class="text-center">
                            <div class="font-display text-3xl font-bold text-primary">10k+</div>
                            <div class="text-sm text-gray-500">Utilisateurs</div>
                        </div>
                        <div class="w-px h-12 bg-gray-200"></div>
                        <div class="text-center">
                            <div class="font-display text-3xl font-bold text-primary">50+</div>
                            <div class="text-sm text-gray-500">Partenaires</div>
                        </div>
                    </div>
                </div>
                <div class="relative hidden lg:block">
                    <div class="relative w-full aspect-square">
                        <div class="absolute inset-0 bg-gradient-to-br from-accent to-accent-dark rounded-[2rem] rotate-6 opacity-20"></div>
                        <div class="absolute inset-0 bg-gradient-to-bl from-primary to-primary-light rounded-[2rem] -rotate-3 opacity-10"></div>
                        <div class="relative bg-surface border border-gray-200 rounded-[2rem] p-8 shadow-2xl">
                            <div class="space-y-6">
                                <div class="flex items-center gap-4">
                                    <div class="w-16 h-16 bg-accent/20 rounded-2xl flex items-center justify-center">
                                        <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
                                    </div>
                                    <div>
                                        <div class="font-semibold text-primary">Concerts Live</div>
                                        <div class="text-sm text-gray-500">Les meilleures artistes</div>
                                    </div>
                                </div>
                                <div class="flex items-center gap-4">
                                    <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center">
                                        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                    </div>
                                    <div>
                                        <div class="font-semibold text-primary">Événements exclusifs</div>
                                        <div class="text-sm text-gray-500">Réservation prioritaire</div>
                                    </div>
                                </div>
                                <div class="flex items-center gap-4">
                                    <div class="w-16 h-16 bg-green-100 rounded-2xl flex items-center justify-center">
                                        <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                                    </div>
                                    <div>
                                        <div class="font-semibold text-primary">Paiement sécurisé</div>
                                        <div class="text-sm text-gray-500">100% sécurisé</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {% if featuredEvents|length > 0 %}
    <section class="py-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <h2 class="font-display text-4xl font-bold text-primary mb-4">Événements à venir</h2>
                <p class="text-xl text-gray-600 max-w-2xl mx-auto">Ne manquez pas ces expériences exceptionnelles</p>
            </div>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                {% for event in featuredEvents %}
                <div class="group bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-2xl hover:shadow-primary/5 transition-all duration-300 hover:-translate-y-2 overflow-hidden">
                    <div class="relative h-48 bg-gradient-to-br from-accent/20 to-primary/20 overflow-hidden">
                        <div class="absolute inset-0 bg-primary/5 group-hover:bg-accent/10 transition-colors"></div>
                        <div class="absolute top-4 right-4 px-3 py-1 bg-white/90 backdrop-blur rounded-full text-sm font-medium text-primary">
                            {{ event.date|date('d M') }}
                        </div>
                        {% if event.seats <= 10 %}
                        <div class="absolute top-4 left-4 px-3 py-1 bg-red-500 text-white text-sm font-medium rounded-full">
                            Plus que {{ event.seats }} places
                        </div>
                        {% endif %}
                    </div>
                    <div class="p-6">
                        <h3 class="font-display text-xl font-semibold text-primary mb-2 group-hover:text-accent transition-colors">{{ event.title }}</h3>
                        <p class="text-gray-600 text-sm mb-4 line-clamp-2">{{ event.description }}</p>
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2 text-sm text-gray-500">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                {{ event.location }}
                            </div>
                            <a href="{{ path('app_event_detail', {id: event.id}) }}" class="px-4 py-2 bg-primary text-white text-sm font-medium rounded-lg hover:bg-primary-light transition-colors">
                                Voir plus
                            </a>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
            <div class="text-center mt-12">
                <a href="{{ path('app_event_list') }}" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-primary border-2 border-gray-200 font-medium rounded-xl hover:border-accent hover:text-accent transition-all">
                    Voir tous les événements
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
            </div>
        </div>
    </section>
    {% endif %}

    <section class="py-20 bg-primary">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center">
                <h2 class="font-display text-4xl font-bold text-white mb-6">Prêt à vivre des moments uniques ?</h2>
                <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">Rejoignez des milliers d'utilisateurs qui réservent leur prochain événement sur EventHub</p>
                <div class="flex flex-wrap justify-center gap-4">
                    <a href="{{ path('app_register') }}" class="px-8 py-4 bg-accent text-white font-medium rounded-xl hover:bg-accent-hover transition-all hover:scale-105">
                        Commencer maintenant
                    </a>
                    <a href="{{ path('app_event_list') }}" class="px-8 py-4 bg-white/10 text-white font-medium rounded-xl hover:bg-white/20 transition-all border border-white/20">
                        Parcourir les événements
                    </a>
                </div>
            </div>
        </div>
    </section>
</div>
{% endblock %}

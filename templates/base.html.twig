<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🐧</text></svg>">

        <script src="https://cdn.tailwindcss.com"></script>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,800&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

        <script>
            tailwind.config = {
                theme: {
                    extend: {
                        colors: {
                            accent: { DEFAULT: '#c1440e', hover: '#a33a0b', light: '#f8e8e0' },
                            warm: { DEFAULT: '#f5f0e8', card: '#fffdf8' },
                        },
                        fontFamily: {
                            display: ['Fraunces', 'serif'],
                            body: ['Outfit', 'sans-serif'],
                        },
                    },
                },
            }
        </script>

        <style>
            body { font-family: 'Outfit', sans-serif; }
            [class*="font-display"] { font-family: 'Fraunces', serif; }
        </style>

        {% block stylesheets %}{% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="bg-warm min-h-screen">

        <nav class="bg-gray-900 border-b-4 border-accent sticky top-0 z-50">
            <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
                <a href="{{ path('app_event_list') }}" class="font-display text-2xl font-extrabold text-gray-100 no-underline tracking-tight">
                    Penguin<span class="text-accent">Events</span>
                </a>
                <div class="flex items-center gap-6">
                    <a href="{{ path('app_event_list') }}" class="text-gray-300 hover:text-accent text-sm font-semibold uppercase tracking-widest transition-colors no-underline">
                        Événements
                    </a>
                    <span id="nav-user" class="text-accent text-sm font-semibold uppercase tracking-widest hidden"></span>
                    <a id="nav-logout" href="{{ path('app_logout') }}" class="text-gray-300 hover:text-accent text-sm font-semibold uppercase tracking-widest transition-colors no-underline hidden" onclick="localStorage.removeItem('jwt_token');localStorage.removeItem('refresh_token');">
                        Déconnexion
                    </a>
                    <a id="nav-login" href="{{ path('app_login') }}" class="text-gray-300 hover:text-accent text-sm font-semibold uppercase tracking-widest transition-colors no-underline">
                        Connexion
                    </a>
                    <a id="nav-register" href="{{ path('app_register') }}" class="bg-accent text-white px-4 py-2 text-sm font-semibold uppercase tracking-widest hover:bg-accent-hover transition-colors no-underline">
                        S'inscrire
                    </a>
                    <script>
                        (function () {
                            const token = localStorage.getItem('jwt_token');
                            if (!token) return;
                            try {
                                const payload = JSON.parse(atob(token.split('.')[1].replace(/-/g, '+').replace(/_/g, '/')));
                                if (!payload || (payload.exp && payload.exp < Date.now() / 1000)) {
                                    localStorage.removeItem('jwt_token');
                                    localStorage.removeItem('refresh_token');
                                    return;
                                }
                                const email = payload.username || payload.email || payload.sub || '';
                                document.getElementById('nav-user').textContent = email;
                                document.getElementById('nav-user').classList.remove('hidden');
                                document.getElementById('nav-logout').classList.remove('hidden');
                                document.getElementById('nav-login').classList.add('hidden');
                                document.getElementById('nav-register').classList.add('hidden');
                            } catch (e) {}
                        })();
                    </script>
                </div>
            </div>
        </nav>

        <main class="max-w-6xl mx-auto px-6 py-8">
            {% for message in app.flashes('success') %}
                <div class="mb-4 p-4 bg-green-50 border-l-4 border-green-600 text-green-800 font-medium">
                    {{ message }}
                </div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="mb-4 p-4 bg-red-50 border-l-4 border-red-600 text-red-800 font-medium">
                    {{ message }}
                </div>
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

    </body>
</html>

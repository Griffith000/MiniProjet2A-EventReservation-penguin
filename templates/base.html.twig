<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect x=%2220%22 y=%2210%22 width=%2260%22 height=%2280%22 rx=%225%22 fill=%22%23111111%22/><circle cx=%2235%22 cy=%2235%22 r=%225%22 fill=%22white%22/><circle cx=%2265%22 cy=%2235%22 r=%225%22 fill=%22white%22/><path d=%22M35 50 Q50 60 65 50%22 stroke=%22white%22 stroke-width=%223%22 fill=%22none%22/></svg>">

        <script src="https://cdn.tailwindcss.com"></script>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">

        <script>
            tailwind.config = {
                theme: {
                    extend: {
                        colors: {
                            primary: { DEFAULT: '#1a1a1a', light: '#2d2d2d' },
                            accent: { DEFAULT: '#d4a574', hover: '#c49565', dark: '#8b6914', light: '#f5ebe0' },
                            surface: { DEFAULT: '#faf9f7', card: '#ffffff' },
                        },
                        fontFamily: {
                            display: ['Playfair Display', 'serif'],
                            body: ['DM Sans', 'sans-serif'],
                        },
                    },
                },
            }
        </script>

        <style>
            body { font-family: 'DM Sans', sans-serif; }
            [class*="font-display"] { font-family: 'Playfair Display', serif; }
            .glass-nav { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); }
        </style>

        {% block stylesheets %}{% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="bg-surface min-h-screen flex flex-col">
        <nav class="glass-nav border-b border-gray-200 sticky top-0 z-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex justify-between items-center h-16">
                    <a href="{{ path('app_event_list') }}" class="font-display text-xl sm:text-2xl font-bold text-primary no-underline tracking-tight">
                        Event<span class="text-accent">Hub</span>
                    </a>
                    
                    <button id="mobile-menu-btn" class="md:hidden p-2 text-primary" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                    </button>

                    <div id="mobile-menu" class="hidden md:flex flex-col md:flex-row absolute md:relative top-16 md:top-0 left-0 md:left-auto right-0 bg-white md:bg-transparent border-t md:border-t-0 border-gray-200 md:border-none p-4 md:p-0 shadow-lg md:shadow-none gap-4 md:gap-6 items-start md:items-center w-full md:w-auto">
                        <a href="{{ path('app_event_list') }}" class="text-primary hover:text-accent text-sm font-medium no-underline transition-colors">
                            Événements
                        </a>
                        {% if app.user %}
                            {% if 'ROLE_ADMIN' in app.user.roles %}
                                <a href="{{ path('app_admin_dashboard') }}" class="text-accent-dark text-sm font-medium hover:text-accent no-underline transition-colors">
                                    Admin
                                </a>
                            {% endif %}
                            <span id="nav-user" class="text-primary text-sm font-medium hidden"></span>
                            <a id="nav-logout" href="{{ path('app_logout') }}" class="text-primary hover:text-accent text-sm font-medium no-underline transition-colors" onclick="localStorage.removeItem('jwt_token');localStorage.removeItem('refresh_token');">
                                Déconnexion
                            </a>
                        {% else %}
                            <span id="nav-user" class="text-primary text-sm font-medium hidden"></span>
                            <a id="nav-logout" href="{{ path('app_logout') }}" class="text-primary hover:text-accent text-sm font-medium hidden no-underline" onclick="localStorage.removeItem('jwt_token');localStorage.removeItem('refresh_token');">
                                Déconnexion
                            </a>
                            <a id="nav-login" href="{{ path('app_login') }}" class="text-primary hover:text-accent text-sm font-medium no-underline transition-colors">
                                Connexion
                            </a>
                            <a id="nav-register" href="{{ path('app_register') }}" class="bg-primary text-white px-4 py-2 text-sm font-medium no-underline hover:bg-primary-light transition-colors">
                                S'inscrire
                            </a>
                        {% endif %}
                    </div>
                    <script>
                        (function () {
                            const token = localStorage.getItem('jwt_token');
                            if (!token) return;
                            try {
                                const payload = JSON.parse(atob(token.split('.')[1].replace(/-/g, '+').replace(/_/g, '/')));
                                if (!payload || (payload.exp && payload.exp < Date.now() / 1000)) {
                                    localStorage.removeItem('jwt_token');
                                    localStorage.removeItem('refresh_token');
                                    return;
                                }
                                const email = payload.username || payload.email || payload.sub || '';
                                document.getElementById('nav-user').textContent = email;
                                document.getElementById('nav-user').classList.remove('hidden');
                                document.getElementById('nav-logout').classList.remove('hidden');
                                document.getElementById('nav-login').classList.add('hidden');
                                document.getElementById('nav-register').classList.add('hidden');
                            } catch (e) {}
                        })();
                    </script>
                </div>
            </div>
        </nav>

        <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full">
            {% for message in app.flashes('success') %}
                <div class="mb-6 p-4 bg-green-50 border border-green-200 text-green-800 font-medium text-sm rounded-lg">
                    {{ message }}
                </div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-800 font-medium text-sm rounded-lg">
                    {{ message }}
                </div>
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        <footer class="bg-primary text-white mt-auto">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
                <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                    <div class="md:col-span-2">
                        <a href="{{ path('app_event_list') }}" class="font-display text-2xl font-bold no-underline tracking-tight">
                            Event<span class="text-accent">Hub</span>
                        </a>
                        <p class="text-gray-400 mt-3 text-sm leading-relaxed max-w-sm">
                            Votre plateforme de réservation d'événements premium. Découvrez et réservez des expériences uniques.
                        </p>
                    </div>
                    <div>
                        <h4 class="font-semibold text-sm uppercase tracking-wider mb-4 text-accent">Navigation</h4>
                        <ul class="space-y-2">
                            <li><a href="{{ path('app_event_list') }}" class="text-gray-400 hover:text-white text-sm transition-colors no-underline">Événements</a></li>
                            {% if not app.user %}
                            <li><a href="{{ path('app_login') }}" class="text-gray-400 hover:text-white text-sm transition-colors no-underline">Connexion</a></li>
                            <li><a href="{{ path('app_register') }}" class="text-gray-400 hover:text-white text-sm transition-colors no-underline">S'inscrire</a></li>
                            {% endif %}
                        </ul>
                    </div>
                    <div>
                        <h4 class="font-semibold text-sm uppercase tracking-wider mb-4 text-accent">Contact</h4>
                        <ul class="space-y-2 text-gray-400 text-sm">
                            <li>contact@eventhub.tn</li>
                            <li>+216 00 000 000</li>
                            <li>Tunis, Tunisie</li>
                        </ul>
                    </div>
                </div>
                <div class="border-t border-gray-800 mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-4">
                    <p class="text-gray-500 text-xs">© 2026 EventHub. Tous droits réservés.</p>
                    <div class="flex gap-4">
                        <a href="#" class="text-gray-500 hover:text-white transition-colors">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
                        </a>
                        <a href="#" class="text-gray-500 hover:text-white transition-colors">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                        </a>
                        <a href="#" class="text-gray-500 hover:text-white transition-colors">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                        </a>
                    </div>
                </div>
            </div>
        </footer>

    </body>
</html>

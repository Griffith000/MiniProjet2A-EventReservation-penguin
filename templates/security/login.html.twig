{% extends "base.html.twig" %}

{% block title %}Connexion{% endblock %}

{% block body %}
    <div class="max-w-md mx-auto mt-8">
        <div class="mb-8">
            <h1 class="font-display text-4xl font-extrabold text-gray-900 mt-2 tracking-tight">Connexion</h1>
            <p class="text-gray-400 mt-2 text-sm">Connectez-vous pour réserver vos événements</p>
        </div>

        {% if error %}
            <div class="mb-6 p-4 bg-red-50 border-l-4 border-red-600 text-red-800 font-medium text-sm">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}" class="bg-warm-card border-2 border-gray-900 p-8">
            <div class="mb-5">
                <label for="username" class="block text-gray-900 text-xs font-bold uppercase tracking-[0.12em] mb-2">
                    Email
                </label>
                <input type="email" id="username" name="_username"
                       value="{{ last_username }}"
                       autocomplete="email"
                       required
                       class="w-full border-2 border-gray-300 bg-white px-4 py-3 text-gray-900 text-sm font-medium focus:outline-none focus:border-gray-900 transition-colors">
            </div>

            <div class="mb-6">
                <label for="password" class="block text-gray-900 text-xs font-bold uppercase tracking-[0.12em] mb-2">
                    Mot de passe
                </label>
                <input type="password" id="password" name="_password"
                       autocomplete="current-password"
                       required
                       class="w-full border-2 border-gray-300 bg-white px-4 py-3 text-gray-900 text-sm font-medium focus:outline-none focus:border-gray-900 transition-colors">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit"
                    class="w-full bg-gray-900 text-white py-3.5 font-bold text-sm uppercase tracking-[0.1em] hover:bg-accent hover:-translate-y-0.5 hover:shadow-[4px_6px_0_rgba(0,0,0,0.2)] active:translate-y-0 active:shadow-none transition-all">
                Se connecter
            </button>
        </form>

        <div class="mt-4 text-center">
            <span class="text-gray-400 text-xs uppercase tracking-widest font-semibold">ou</span>
        </div>

        <button id="passkey-login-btn"
                class="mt-4 w-full border-2 border-gray-900 bg-white text-gray-900 py-3.5 font-bold text-sm uppercase tracking-[0.1em] hover:bg-gray-900 hover:text-white hover:-translate-y-0.5 active:translate-y-0 transition-all flex items-center justify-center gap-2">
            <span>🔑</span> Se connecter avec une Passkey
        </button>

        <p id="passkey-msg" class="mt-3 text-sm text-center font-medium hidden"></p>

        <p class="mt-6 text-center text-sm text-gray-500">
            Pas encore de compte ?
            <a href="{{ path('app_register') }}" class="text-accent font-semibold hover:underline">S'inscrire avec une Passkey</a>
        </p>
    </div>

{% block javascripts %}
    {{ parent() }}
    <script type="module">
        import { loginWithPasskey } from '/js/auth.js';

        const redirectUrl = new URLSearchParams(window.location.search).get('redirect') || '/login/redirect';

        document.getElementById('passkey-login-btn').addEventListener('click', async () => {
            const msg = document.getElementById('passkey-msg');
            msg.className = 'mt-3 text-sm text-center font-medium';
            msg.textContent = 'Authentification en cours…';
            msg.classList.remove('hidden');
            try {
                await loginWithPasskey();
                msg.textContent = 'Connecté ! Redirection…';
                msg.classList.add('text-green-700');
                window.location.href = redirectUrl;
            } catch (e) {
                msg.textContent = e.message;
                msg.classList.add('text-red-700');
            }
        });
    </script>
{% endblock %}
{% endblock %}

{% extends "base.html.twig" %}

{% block title %}S'inscrire{% endblock %}

{% block body %}
    <div class="max-w-md mx-auto">
        <div class="text-center mb-8">
            <span class="text-accent font-semibold text-xs uppercase tracking-[0.25em]">Nouveau compte</span>
            <h1 class="font-display text-3xl sm:text-4xl font-bold text-primary mt-2 tracking-tight">S'inscrire</h1>
        </div>

        <div class="bg-card border border-gray-200 p-1 mb-6 rounded-lg flex">
            <button type="button" id="toggle-password" class="toggle-btn active flex-1 py-3 font-medium text-sm rounded-md transition-all">
                Email
            </button>
            <button type="button" id="toggle-passkey" class="toggle-btn flex-1 py-3 font-medium text-sm text-gray-400 rounded-md transition-all">
                Passkey
            </button>
        </div>

        {# Password registration form #}
        <div id="form-password" class="registration-form">
            <form method="post" action="{{ path('app_register') }}" class="bg-card border border-gray-100 shadow-lg p-8 rounded-xl">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('register') }}">
                
                <div class="mb-5">
                    <label for="email" class="block text-primary text-sm font-medium mb-2">
                        Email
                    </label>
                    <input type="email" id="email" name="email"
                           autocomplete="email"
                           placeholder="vous@exemple.com"
                           required
                           class="w-full border border-gray-200 bg-surface px-4 py-3 text-primary text-sm rounded-lg focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors">
                </div>

                <div class="mb-5">
                    <label for="password" class="block text-primary text-sm font-medium mb-2">
                        Mot de passe
                    </label>
                    <input type="password" id="password" name="password"
                           autocomplete="new-password"
                           placeholder="••••••••"
                           required
                           minlength="6"
                           class="w-full border border-gray-200 bg-surface px-4 py-3 text-primary text-sm rounded-lg focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors">
                </div>

                <button type="submit"
                        class="w-full bg-primary text-white py-3.5 font-medium text-sm rounded-lg hover:bg-accent hover:-translate-y-0.5 hover:shadow-lg transition-all">
                    Créer mon compte
                </button>
            </form>
        </div>

        {# Passkey registration form #}
        <div id="form-passkey" class="registration-form hidden">
            <form method="post" class="bg-card border border-gray-100 shadow-lg p-8 rounded-xl">
                <p class="text-gray-500 mb-5 text-sm">Créez votre compte avec une Passkey — plus besoin de mot de passe</p>
                
                <div class="mb-5">
                    <label for="passkey-email" class="block text-primary text-sm font-medium mb-2">
                        Email
                    </label>
                    <input type="email" id="passkey-email" name="passkey_email"
                           autocomplete="email"
                           placeholder="vous@exemple.com"
                           required
                           class="w-full border border-gray-200 bg-surface px-4 py-3 text-primary text-sm rounded-lg focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors">
                </div>

                <button type="button" id="register-passkey-btn"
                        class="w-full bg-primary text-white py-3.5 font-medium text-sm rounded-lg hover:bg-accent hover:-translate-y-0.5 hover:shadow-lg transition-all flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
                    Créer ma Passkey
                </button>

                <p id="register-msg" class="mt-4 text-sm text-center font-medium hidden"></p>
            </form>
        </div>

        <p class="mt-8 text-center text-sm text-gray-500">
            Déjà un compte ?
            <a href="{{ path('app_login') }}" class="text-accent-dark font-medium hover:underline">Se connecter</a>
        </p>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="module">
        import { registerPasskey } from '/js/auth.js';

        const togglePassword = document.getElementById('toggle-password');
        const togglePasskey = document.getElementById('toggle-passkey');
        const formPassword = document.getElementById('form-password');
        const formPasskey = document.getElementById('form-passkey');

        togglePassword.addEventListener('click', () => {
            togglePassword.classList.add('active', 'text-white');
            togglePassword.classList.remove('text-gray-400');
            togglePasskey.classList.remove('active', 'text-white');
            togglePasskey.classList.add('text-gray-400');
            formPassword.classList.remove('hidden');
            formPasskey.classList.add('hidden');
        });

        togglePasskey.addEventListener('click', () => {
            togglePasskey.classList.add('active', 'text-white');
            togglePasskey.classList.remove('text-gray-400');
            togglePassword.classList.remove('active', 'text-white');
            togglePassword.classList.add('text-gray-400');
            formPasskey.classList.remove('hidden');
            formPassword.classList.add('hidden');
        });

        document.getElementById('register-passkey-btn').addEventListener('click', async () => {
            const email = document.getElementById('passkey-email').value.trim();
            const msg = document.getElementById('register-msg');

            if (!email) {
                msg.textContent = 'Veuillez saisir votre email.';
                msg.className = 'mt-4 text-sm text-center font-medium text-red-600';
                msg.classList.remove('hidden');
                return;
            }

            msg.textContent = 'Création de la passkey…';
            msg.className = 'mt-4 text-sm text-center font-medium text-gray-600';
            msg.classList.remove('hidden');

            try {
                await registerPasskey(email, email);
                msg.textContent = 'Passkey créée ! Redirection…';
                msg.className = 'mt-4 text-sm text-center font-medium text-green-600';
                window.location.href = '/events';
            } catch (e) {
                msg.textContent = e.message;
                msg.className = 'mt-4 text-sm text-center font-medium text-red-600';
            }
        });
    </script>
    <style>
        .toggle-btn {
            background: #f3f4f6;
            color: #666;
        }
        .toggle-btn.active {
            background: #d4a574;
            color: #fff;
        }
    </style>
{% endblock %}

{% extends "base.html.twig" %}

{% block title %}S'inscrire{% endblock %}

{% block body %}
    <div class="max-w-md mx-auto mt-8">
        <div class="mb-8">
            <span class="text-accent font-semibold text-xs uppercase tracking-[0.2em]">Nouveau compte</span>
            <h1 class="font-display text-4xl font-extrabold text-gray-900 mt-2 tracking-tight">S'inscrire</h1>
            <p class="text-gray-400 mt-2 text-sm">Créez votre compte avec une Passkey — sans mot de passe</p>
        </div>

        <div class="bg-warm-card border-2 border-gray-900 p-8">
            <div class="mb-5">
                <label for="email" class="block text-gray-900 text-xs font-bold uppercase tracking-[0.12em] mb-2">
                    Email
                </label>
                <input type="email" id="email" name="email"
                       autocomplete="email"
                       placeholder="vous@exemple.com"
                       required
                       class="w-full border-2 border-gray-300 bg-white px-4 py-3 text-gray-900 text-sm font-medium focus:outline-none focus:border-gray-900 transition-colors">
            </div>

            <button id="register-passkey-btn"
                    class="w-full bg-gray-900 text-white py-3.5 font-bold text-sm uppercase tracking-[0.1em] hover:bg-accent hover:-translate-y-0.5 hover:shadow-[4px_6px_0_rgba(0,0,0,0.2)] active:translate-y-0 active:shadow-none transition-all flex items-center justify-center gap-2">
                <span>🔑</span> Créer ma Passkey
            </button>

            <p id="register-msg" class="mt-4 text-sm text-center font-medium hidden"></p>
        </div>

        <p class="mt-6 text-center text-sm text-gray-500">
            Déjà un compte ?
            <a href="{{ path('app_login') }}" class="text-accent font-semibold hover:underline">Se connecter</a>
        </p>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="module">
        import { registerPasskey } from '/js/auth.js';

        document.getElementById('register-passkey-btn').addEventListener('click', async () => {
            const email = document.getElementById('email').value.trim();
            const msg = document.getElementById('register-msg');

            if (!email) {
                msg.textContent = 'Veuillez saisir votre email.';
                msg.className = 'mt-4 text-sm text-center font-medium text-red-700';
                msg.classList.remove('hidden');
                return;
            }

            msg.textContent = 'Création de la passkey…';
            msg.className = 'mt-4 text-sm text-center font-medium text-gray-700';
            msg.classList.remove('hidden');

            try {
                await registerPasskey(email, email);
                msg.textContent = 'Passkey créée ! Redirection…';
                msg.className = 'mt-4 text-sm text-center font-medium text-green-700';
                window.location.href = '/events';
            } catch (e) {
                msg.textContent = e.message;
                msg.className = 'mt-4 text-sm text-center font-medium text-red-700';
            }
        });
    </script>
{% endblock %}
